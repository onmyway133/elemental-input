{
  "compilerOptions": {
    "target":            "ES2017",
    "lib":               ["ES2017", "DOM"],
    "module":            "ESNext",
    "moduleResolution":  "Bundler",
    "jsx":               "react-jsx",
    "strict":            true,
    "declaration":       true,
    "declarationMap":    true,
    "sourceMap":         true,
    "esModuleInterop":   true,
    "skipLibCheck":      true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
